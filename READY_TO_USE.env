# ============================================================================
# BoyFanz Production Configuration for boyzapp.com
# READY TO USE - Just add your Supabase credentials
# ============================================================================

NODE_ENV=production
PORT=3000

# ============================================================================
# DATABASE - Supabase PostgreSQL (FILL IN YOUR CREDENTIALS)
# ============================================================================
# Get these from: https://supabase.com/dashboard/project/ysjondxpwvfjofbneqki

# 1. Get Database Password:
#    Settings → Database → Connection string → Copy the password part
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.ysjondxpwvfjofbneqki.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.ysjondxpwvfjofbneqki.supabase.co:5432/postgres

# 2. Get API Keys:
#    Settings → API → Copy these three values

# Project URL (this is correct, don't change)
SUPABASE_URL=https://ysjondxpwvfjofbneqki.supabase.co

# anon public key (starts with eyJ...)
SUPABASE_ANON_KEY=GET_FROM_SUPABASE_DASHBOARD_SETTINGS_API

# service_role key (starts with eyJ...)
SUPABASE_SERVICE_ROLE_KEY=GET_FROM_SUPABASE_DASHBOARD_SETTINGS_API

# PostgreSQL Connection Details
PGHOST=db.ysjondxpwvfjofbneqki.supabase.co
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=YOUR_SUPABASE_PASSWORD

# ============================================================================
# APPLICATION URLS
# ============================================================================
WEB_APP_URL=https://boyzapp.com
API_URL=https://boyzapp.com/api
DOMAIN=boyzapp.com

# ============================================================================
# SECURITY SECRETS - GENERATE THESE!
# ============================================================================
# Generate at: https://randomkeygen.com/ (use CodeIgniter Encryption Keys)
# Or run: openssl rand -hex 32

JWT_ISS=boyzapp.com
JWT_AUD=boyzapp.clients
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_SECRET=GENERATE_64_CHAR_RANDOM_STRING_FROM_RANDOMKEYGEN
SESSION_SECRET=GENERATE_64_CHAR_RANDOM_STRING_FROM_RANDOMKEYGEN

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
OTP_EMAIL_FROM=noreply@boyzapp.com

# Optional SMTP (configure after deployment)
# SMTP_HOST=mail.boyzapp.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@boyzapp.com
# SMTP_PASSWORD=your_email_password

# ============================================================================
# PUSH NOTIFICATIONS (Optional - can add later)
# ============================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ============================================================================
# OBJECT STORAGE (Optional - can add later)
# ============================================================================
PUBLIC_OBJECT_SEARCH_PATHS=/boyzapp-public/assets
PRIVATE_OBJECT_DIR=/boyzapp-private

# ============================================================================
# KYC/VERIFICATION (Optional - can add later)
# ============================================================================
VERIFYMY_API_URL=https://api.verifymy.com
VERIFYMY_API_KEY=

# ============================================================================
# PAYMENT GATEWAYS (Configure after deployment)
# ============================================================================

# Host Merchant Services
HMS_API_URL=https://api.hostmerchantservices.com/v1
HMS_API_KEY=
HMS_MERCHANT_ID=

# FanzDash Integration
FANZ_DASH_API_URL=https://api.fanzdash.com/v1
FANZ_DASH_API_KEY=
FANZ_DASH_WEBHOOK_SECRET=

# CCBill
CCBILL_CLIENT_ACCNUM=
CCBILL_CLIENT_SUBACC=
CCBILL_FORM_NAME=
CCBILL_SALT=

# Segpay
SEGPAY_PACKAGE_ID=
SEGPAY_USERID=
SEGPAY_ACCESS_KEY=

PAYMENT_GATEWAYS_ENABLED=ccbill,segpay
PAYOUT_PROVIDERS=paxum,epayservice

# ============================================================================
# INSTRUCTIONS TO GET CREDENTIALS
# ============================================================================
#
# SUPABASE CREDENTIALS (Required - Do This First):
# ------------------------------------------------
# 1. Go to: https://supabase.com/dashboard/project/ysjondxpwvfjofbneqki
# 2. Click "Settings" (gear icon) in left sidebar
# 3. Click "Database"
#    - Find "Connection string" section
#    - Click "URI" tab
#    - You'll see: postgresql://postgres:[YOUR-PASSWORD]@db...
#    - Copy the password and replace YOUR_SUPABASE_PASSWORD above (3 places)
#
# 4. Click "API" in Settings
#    - Copy "Project URL" - should be https://ysjondxpwvfjofbneqki.supabase.co
#    - Copy "anon public" key - paste for SUPABASE_ANON_KEY
#    - Copy "service_role" key - paste for SUPABASE_SERVICE_ROLE_KEY
#
# SECURITY SECRETS (Required - Do This Second):
# --------------------------------------------
# 1. Go to: https://randomkeygen.com/
# 2. Copy a "CodeIgniter Encryption Key" (256-bit)
# 3. Paste for JWT_SECRET
# 4. Copy another one
# 5. Paste for SESSION_SECRET
#
# THAT'S IT! The rest is optional and can be configured later.
#
# ============================================================================
