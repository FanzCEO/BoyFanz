# BoyFanz Production Configuration for boyzapp.com
# Server: 67.217.54.66
# cPanel User: boyzapp
# Domain: boyzapp.com
# Nameservers: ns1.fanzgroupholdings.com, ns2.fanzgroupholdings.com

NODE_ENV=production
PORT=3000

# Database Configuration - PostgreSQL
# Create database in cPanel: MySQL/PostgreSQL Database Manager
DATABASE_URL=postgresql://boyzapp_user:YOUR_DB_PASSWORD@localhost:5432/boyzapp_db

# PostgreSQL Connection Details
PGHOST=localhost
PGPORT=5432
PGDATABASE=boyzapp_db
PGUSER=boyzapp_user
PGPASSWORD=YOUR_DB_PASSWORD

# Application URLs
WEB_APP_URL=https://boyzapp.com
API_URL=https://boyzapp.com/api
DOMAIN=boyzapp.com

# Security - GENERATE NEW SECRETS FOR PRODUCTION!
# Use: openssl rand -hex 32
JWT_ISS=boyzapp.com
JWT_AUD=boyzapp.clients
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHARACTER_SECRET_KEY_FOR_JWT
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_32_BYTE_HEX_SESSION_SECRET

# Email Configuration
OTP_EMAIL_FROM=noreply@boyzapp.com

# Push Notifications (Optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Object Storage Configuration
PUBLIC_OBJECT_SEARCH_PATHS=/boyzapp-public/assets
PRIVATE_OBJECT_DIR=/boyzapp-private

# KYC/VerifyMy Integration
VERIFYMY_API_URL=https://api.verifymy.com
VERIFYMY_API_KEY=YOUR_VERIFYMY_API_KEY

# =============================================================================
# ADULT-FRIENDLY PAYMENT CONFIGURATION
# =============================================================================

# Host Merchant Services (HMS)
HMS_API_URL=https://api.hostmerchantservices.com/v1
HMS_API_KEY=YOUR_HMS_API_KEY
HMS_MERCHANT_ID=YOUR_HMS_MERCHANT_ID

# FanzDash Integration
FANZ_DASH_API_URL=https://api.fanzdash.com/v1
FANZ_DASH_API_KEY=YOUR_FANZDASH_API_KEY
FANZ_DASH_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# Payment Gateways
CCBILL_CLIENT_ACCNUM=YOUR_CCBILL_ACCOUNT
CCBILL_CLIENT_SUBACC=YOUR_CCBILL_SUBACCOUNT
CCBILL_FORM_NAME=YOUR_FORM_NAME
CCBILL_SALT=YOUR_CCBILL_SALT

SEGPAY_PACKAGE_ID=YOUR_SEGPAY_PACKAGE
SEGPAY_USERID=YOUR_SEGPAY_USERID
SEGPAY_ACCESS_KEY=YOUR_SEGPAY_ACCESS_KEY

PAYMENT_GATEWAYS_ENABLED=ccbill,segpay
PAYOUT_PROVIDERS=paxum,epayservice
